# Local API configuration for netlist_to_canonical_asc.py
# Copy this file to .env and fill in only the values you need.

# Required for: --vision-review --vision-provider openai
OPENAI_API_KEY=

# Required for: --vision-review --vision-provider minimax
MINIMAX_API_KEY=
MINIMAX_API_HOST=https://api.minimax.io

# Optional defaults used by the CLI.
# VISION_PROVIDER can be openai or minimax.
VISION_PROVIDER=openai
VISION_REVIEW_MODEL=
